# Copy this file to .env and update with your values
# This file should NOT be committed to git

# Admin IP address for WAF whitelist (include /32 for single IP)
ADMIN_IP=YOUR_IP_HERE/32

# Database retention policy: RETAIN (default) or DELETE
# RETAIN: Database will be preserved when stack is deleted
# DELETE: Database will be deleted when stack is deleted (use for development)
DATABASE_RETENTION=RETAIN

# Optional: Override default values
# PROJECT_NAME=strapi
# ENVIRONMENT=production
# AWS_REGION=us-west-2
# DB_USERNAME=strapiuser
# DB_PASSWORD=StrapiDBPass2024Secure