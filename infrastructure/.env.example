# Strapi AWS Deployment Configuration
# Copy this file to .env and update with your values

# Project Configuration
PROJECT_NAME=strapi
ENVIRONMENT=dev
AWS_REGION=us-west-2

# Database Configuration
# RETAIN: Database will be retained when stack is deleted (recommended for production)
# DELETE: Database will be deleted when stack is deleted (use for testing only)
DATABASE_RETENTION=RETAIN

# Security Configuration
# Admin IP addresses allowed to access Strapi admin panel
# Format: Single IP with CIDR (x.x.x.x/32) or comma-separated list (x.x.x.x/32,y.y.y.y/32)
# Default: 0.0.0.0/0 (open to world - NOT RECOMMENDED for production)
# Example: ADMIN_IPS=203.0.113.0/32,198.51.100.0/32
ADMIN_IPS=0.0.0.0/0

# Optional: Database username (default: strapiuser)
# DB_USERNAME=strapiuser

# Optional: S3 bucket for CloudFormation templates
# If not set, will be required via command line
# TEMPLATES_BUCKET=strapi-cloudformation-templates-YOUR-ACCOUNT-ID